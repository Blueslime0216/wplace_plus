{
  "manifest_version": 3,
  "name": "WPlace+",
  "version": "0.0.1",
  "description": "Enhanced WPlace experience with floating modal interface",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://wplace.live/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://wplace.live/*"
      ],
      "js": [
        "js/core/core.js",
        "js/utils/helpers.js",
        "js/features/modal.js",
        "js/features/interactions.js",
        "js/features/ui.js",
        "js/features/language.js",
        "js/app.js"
      ],
      "css": [
        "css/base/variables.css",
        "css/base/modal.css",
        "css/base/responsive.css",
        "css/layout/header.css",
        "css/layout/content.css",
        "css/components/sections.css",
        "css/components/controls.css",
        "css/components/colors.css",
        "css/components/resize.css"
      ],
      "run_at": "document_start"
    }
  ]
}
